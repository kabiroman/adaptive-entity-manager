# Baseline (phpstan-baseline.neon): legacy suppressions only; remove entries as you fix code — do not extend without a fix (see docs/roadmap/tactical-plan-php-compat-and-quality.md).
includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - tests
    excludePaths:
        - tests/bootstrap.php
