			count: 1
			path: src/AdaptiveEntityManager.php

		-
			message: '#^Return type \(Doctrine\\Persistence\\Mapping\\ClassMetadataFactory\<Kabiroman\\AEM\\ClassMetadata\<object\>\>\) of method Kabiroman\\AEM\\AdaptiveEntityManager\:\:getMetadataFactory\(\) should be compatible with return type \(Doctrine\\Persistence\\Mapping\\ClassMetadataFactory\<Doctrine\\Persistence\\Mapping\\ClassMetadata\<object\>\>\) of method Doctrine\\Persistence\\ObjectManager\:\:getMetadataFactory\(\)$#'
			identifier: method.childReturnType
			count: 1
			path: src/AdaptiveEntityManager.php

		-
			message: '#^Call to an undefined method ReflectionType\:\:getName\(\)\.$#'
			identifier: method.notFound
			count: 2
			path: src/EntityFactory.php

		-
			message: '#^PHPDoc tag @return contains generic type Kabiroman\\AEM\\ClassMetadata\<object\> but interface Kabiroman\\AEM\\ClassMetadata is not generic\.$#'
			identifier: generics.notGeneric
			count: 2
			path: src/EntityManagerInterface.php

		-
			message: '#^Return type \(Doctrine\\Persistence\\Mapping\\ClassMetadataFactory\<Kabiroman\\AEM\\ClassMetadata\<object\>\>\) of method Kabiroman\\AEM\\EntityManagerInterface\:\:getMetadataFactory\(\) should be compatible with return type \(Doctrine\\Persistence\\Mapping\\ClassMetadataFactory\<Doctrine\\Persistence\\Mapping\\ClassMetadata\<object\>\>\) of method Doctrine\\Persistence\\ObjectManager\:\:getMetadataFactory\(\)$#'
