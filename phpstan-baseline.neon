parameters:
	ignoreErrors:
		-
			message: '#^Method Kabiroman\\AEM\\AdaptiveEntityManager\:\:getRepository\(\) should return Kabiroman\\AEM\\EntityRepository but returns Doctrine\\Persistence\\ObjectRepository\<T of object\>\.$#'
